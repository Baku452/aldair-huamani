---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import LanguageToggle from './LanguageToggle.astro';
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/" data-i18n="home">Home</HeaderLink>
      <HeaderLink href="/projects" data-i18n="projects">Projects</HeaderLink>
    </div>
    <div class="header-actions">
      <LanguageToggle />
      <div class="social-links">
        <a href="https://www.instagram.com/aldair_alda/" target="_blank">
          <span class="sr-only">Follow Alda on Instagram</span>
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M7.75 2C4.574 2 2 4.574 2 7.75v8.5C2 19.426 4.574 22 7.75 22h8.5C19.426 22 22 19.426 22 16.25v-8.5C22 4.574 19.426 2 16.25 2h-8.5zm0 2h8.5C18.544 4 20 5.456 20 7.75v8.5C20 18.544 18.544 20 16.25 20h-8.5C5.456 20 4 18.544 4 16.25v-8.5C4 5.456 5.456 4 7.75 4zm9.25 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: var(--bg);
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    border-bottom: 1px solid var(--card-bg);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--headline);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--highlight);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1em;
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }
</style>
