---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Aldair Huamani Cusi. <span data-i18n="allRightsReserved">All rights reserved.</span>
	<div class="social-links">
		<a href="https://www.instagram.com/aldair_alda/" target="_blank">
			<span class="sr-only">Follow Alda on Instagram</span>
			<svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true">
				<path d="M7.75 2C4.574 2 2 4.574 2 7.75v8.5C2 19.426 4.574 22 7.75 22h8.5C19.426 22 22 19.426 22 16.25v-8.5C22 4.574 19.426 2 16.25 2h-8.5zm0 2h8.5C18.544 4 20 5.456 20 7.75v8.5C20 18.544 18.544 20 16.25 20h-8.5C5.456 20 4 18.544 4 16.25v-8.5C4 5.456 5.456 4 7.75 4zm9.25 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z"/>
			</svg>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: var(--card-bg);
		color: var(--paragraph);
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: var(--paragraph);
	}
	.social-links a:hover {
		color: var(--highlight);
	}
</style>
