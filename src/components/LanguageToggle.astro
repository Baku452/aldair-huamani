---

<button class="lang-toggle" id="lang-toggle" type="button" aria-label="Toggle language">
	<span class="lang-option" data-lang="en">EN</span>
	<span class="lang-separator">/</span>
	<span class="lang-option" data-lang="es">ES</span>
</button>

<script>
	function initLangToggle() {
		const toggle = document.getElementById('lang-toggle');
		if (!toggle) return;

		const currentLang = localStorage.getItem('lang') || 'en';
		updateToggleUI(currentLang);

		toggle.addEventListener('click', () => {
			const lang = localStorage.getItem('lang') || 'en';
			const newLang = lang === 'en' ? 'es' : 'en';
			localStorage.setItem('lang', newLang);
			updateToggleUI(newLang);
			document.dispatchEvent(new CustomEvent('langchange', { detail: { lang: newLang } }));
		});
	}

	function updateToggleUI(lang: string) {
		document.querySelectorAll('.lang-option').forEach((el) => {
			const element = el as HTMLElement;
			element.classList.toggle('active', element.dataset.lang === lang);
		});
	}

	initLangToggle();
	document.addEventListener('astro:after-swap', initLangToggle);
</script>

<style>
	.lang-toggle {
		display: flex;
		align-items: center;
		gap: 0.25em;
		background: var(--card-bg);
		border: 2px solid var(--stroke);
		border-radius: 20px;
		padding: 0.3em 0.75em;
		cursor: pointer;
		font-family: inherit;
		font-size: 0.8em;
		font-weight: 700;
		color: var(--paragraph);
		transition: border-color 0.15s ease;
	}

	.lang-toggle:hover {
		border-color: var(--highlight);
	}

	.lang-option {
		transition: color 0.15s ease;
	}

	.lang-option.active {
		color: var(--highlight);
	}

	.lang-separator {
		color: var(--paragraph);
		opacity: 0.4;
	}
</style>
