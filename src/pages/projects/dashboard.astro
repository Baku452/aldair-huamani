---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Bug Tracker - ${SITE_TITLE}`} description="Track reported bugs and their status" />
	</head>
	<body>
		<Header />
		<main>
			<div class="dashboard-header">
				<div class="dashboard-title">
					<a href="/projects" class="back-link">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M19 12H5"/>
							<polyline points="12 19 5 12 12 5"/>
						</svg>
						<span data-i18n="backToProjects">Back to Projects</span>
					</a>
					<h1 data-i18n="dashboardTitle">Bug Tracker Dashboard</h1>
					<p data-i18n="dashboardDesc">Track the status of reported bugs across all projects.</p>
				</div>
			</div>

			<div class="stats-grid">
				<div class="stat-card">
					<span class="stat-number" id="stat-total">0</span>
					<span class="stat-label" data-i18n="totalReports">Total Reports</span>
				</div>
				<div class="stat-card stat-open">
					<span class="stat-number" id="stat-open">0</span>
					<span class="stat-label" data-i18n="openIssues">Open Issues</span>
				</div>
				<div class="stat-card stat-progress">
					<span class="stat-number" id="stat-progress">0</span>
					<span class="stat-label" data-i18n="inProgress">In Progress</span>
				</div>
				<div class="stat-card stat-fixed">
					<span class="stat-number" id="stat-fixed">0</span>
					<span class="stat-label" data-i18n="resolved">Resolved</span>
				</div>
			</div>

			<div class="filters">
				<button class="filter-btn active" data-filter="all" data-i18n="filterAll">All</button>
				<button class="filter-btn" data-filter="open" data-i18n="filterOpen">Open</button>
				<button class="filter-btn" data-filter="in-progress" data-i18n="filterInProgress">In Progress</button>
				<button class="filter-btn" data-filter="fixed" data-i18n="filterFixed">Fixed</button>
			</div>

			<div class="bug-list" id="bug-list">
				<p class="empty-state" data-i18n="noBugsFound">No bug reports found.</p>
			</div>

			<!-- Attachment Modal -->
			<div class="modal-overlay" id="attachment-modal" style="display: none;">
				<div class="modal-content">
					<div class="modal-header">
						<h3 id="modal-title" data-i18n="addAttachment">Add Attachment</h3>
						<button class="modal-close" id="modal-close">&times;</button>
					</div>
					<p class="modal-issue-info" id="modal-issue-info"></p>
					<div class="form-group">
						<label for="modal-file" data-i18n="uploadFile">Upload File</label>
						<input type="file" id="modal-file" accept="image/*,.pdf,.log,.txt" multiple />
						<span class="file-hint" data-i18n="fileHint">Supports images, PDF, .log, and .txt (max 50MB per file)</span>
					</div>
					<button class="btn btn-submit" id="modal-submit" data-i18n="uploadAttachment">Upload Attachment</button>
					<p class="modal-status" id="modal-status" style="display: none;"></p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<script>
	import { upload } from '@vercel/blob/client';
	import { translations } from '../../i18n';
	type Lang = keyof typeof translations;
	type TranslationKey = keyof (typeof translations)['en'];

	const REPO = 'Baku452/pdf-selector';

	interface GitHubIssue {
		number: number;
		title: string;
		body: string;
		state: string;
		html_url: string;
		created_at: string;
		user: { login: string };
		labels: { name: string }[];
	}

	interface BugReport {
		id: number;
		title: string;
		description: string;
		status: string;
		date: string;
		reporter: string;
		url: string;
		hasAttachment: boolean;
	}

	const statusLabels: Record<string, Record<string, string>> = {
		en: { open: 'Open', 'in-progress': 'In Progress', fixed: 'Fixed' },
		es: { open: 'Abierto', 'in-progress': 'En Progreso', fixed: 'Resuelto' },
	};

	let currentFilter = 'all';
	let allReports: BugReport[] = [];

	function getLang(): Lang {
		return (localStorage.getItem('lang') || 'en') as Lang;
	}

	function mapStatus(issue: GitHubIssue): string {
		const labels = issue.labels.map((l) => l.name.toLowerCase());
		if (labels.includes('fixed') || issue.state === 'closed') return 'fixed';
		if (labels.includes('in-progress') || labels.includes('wip')) return 'in-progress';
		return 'open';
	}

	function parseReporter(body: string | null): string {
		if (!body) return 'Unknown';
		const match = body.match(/\*\*Reported by:\*\*\s*(.+)/);
		return match ? match[1].trim() : 'Unknown';
	}

	async function fetchIssues(): Promise<BugReport[]> {
		const url =
			`https://api.github.com/repos/${REPO}/issues` +
			`?labels=bug&state=all&per_page=100`;
		const res = await fetch(url, {
			headers: { Accept: 'application/vnd.github+json' },
			cache: 'no-store',
		});

		if (!res.ok) return [];

		const issues: GitHubIssue[] = await res.json();
		return issues
			.filter((i) => !i.title.startsWith('[PR]'))
			.map((issue) => ({
				id: issue.number,
				title: issue.title.replace(/^\[Bug\]\s*/i, ''),
				description: issue.body
					? issue.body.replace(/## Bug Report[\s\S]*?### Description\n\n/m, '').replace(/\n\n### Attachments?[\s\S]*$/, '').slice(0, 200)
					: '',
				status: mapStatus(issue),
				date: issue.created_at,
				reporter: parseReporter(issue.body),
				url: issue.html_url,
				hasAttachment: issue.body ? (issue.body.includes('### Attachment') || issue.body.includes('### Attachments')) : false,
			}));
	}

	function updateStats(reports: BugReport[]) {
		const total = reports.length;
		const open = reports.filter((r) => r.status === 'open').length;
		const progress = reports.filter((r) => r.status === 'in-progress').length;
		const fixed = reports.filter((r) => r.status === 'fixed').length;

		(document.getElementById('stat-total') as HTMLElement).textContent = total.toString();
		(document.getElementById('stat-open') as HTMLElement).textContent = open.toString();
		(document.getElementById('stat-progress') as HTMLElement).textContent = progress.toString();
		(document.getElementById('stat-fixed') as HTMLElement).textContent = fixed.toString();
	}

	function escapeHtml(text: string): string {
		const div = document.createElement('div');
		div.textContent = text;
		return div.innerHTML;
	}

	function renderReports() {
		const lang = getLang();
		const bugList = document.getElementById('bug-list') as HTMLElement;
		const reportedByLabel = translations[lang].reportedBy;

		updateStats(allReports);

		const filtered =
			currentFilter === 'all'
				? allReports
				: allReports.filter((r) => r.status === currentFilter);

		if (filtered.length === 0) {
			bugList.innerHTML =
				`<p class="empty-state">${translations[lang].noBugsFound}</p>`;
			return;
		}

		const addAttachmentLabel = translations[lang].addAttachment || 'Add Attachment';
		const hasAttachmentLabel = translations[lang].hasAttachment || 'Has Attachment';

		bugList.innerHTML = filtered
			.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
			.map(
				(report) => `
				<div class="bug-card" data-status="${report.status}">
					<a class="bug-card-link" href="${escapeHtml(report.url)}" target="_blank">
						<div class="bug-card-header">
							<div class="bug-info">
								<h3>#${report.id} ${escapeHtml(report.title)}</h3>
							</div>
							<span class="status-badge status-${report.status}">
								${statusLabels[lang]?.[report.status] || report.status}
							</span>
						</div>
						<p class="bug-description">${escapeHtml(report.description)}</p>
					</a>
					<div class="bug-meta">
						<span>${reportedByLabel} ${escapeHtml(report.reporter)}</span>
						<div class="bug-meta-right">
							${report.hasAttachment ? `<span class="attachment-badge">${hasAttachmentLabel}</span>` : ''}
							<button class="btn-attach" data-issue="${report.id}" data-title="${escapeHtml(report.title)}">${addAttachmentLabel}</button>
							<span>${new Date(report.date).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
						</div>
					</div>
				</div>
			`,
			)
			.join('');

		// Bind attachment buttons
		bugList.querySelectorAll('.btn-attach').forEach((btn) => {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				const issueId = (btn as HTMLElement).dataset.issue;
				const issueTitle = (btn as HTMLElement).dataset.title;
				openAttachmentModal(Number(issueId), issueTitle || '');
			});
		});
	}

	// Filter buttons
	document.querySelectorAll('.filter-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');
			currentFilter = (btn as HTMLElement).dataset.filter || 'all';
			renderReports();
		});
	});

	// i18n
	function applyLang(lang: Lang) {
		const t = translations[lang];
		document.documentElement.lang = lang;
		document.querySelectorAll('[data-i18n]').forEach((el) => {
			const key = (el as HTMLElement).dataset.i18n as TranslationKey;
			if (t[key]) el.textContent = t[key];
		});
		renderReports();
	}

	// Init: fetch issues then render
	const lang = getLang();
	const bugList = document.getElementById('bug-list') as HTMLElement;
	bugList.innerHTML = '<p class="empty-state loading">Loading...</p>';

	fetchIssues().then((reports) => {
		allReports = reports;
		applyLang(lang);
	});

	document.addEventListener('langchange', (e) => {
		applyLang((e as CustomEvent).detail.lang as Lang);
	});

	// Attachment modal logic
	const modal = document.getElementById('attachment-modal') as HTMLElement;
	const modalClose = document.getElementById('modal-close') as HTMLElement;
	const modalFile = document.getElementById('modal-file') as HTMLInputElement;
	const modalSubmit = document.getElementById('modal-submit') as HTMLButtonElement;
	const modalStatus = document.getElementById('modal-status') as HTMLElement;
	const modalIssueInfo = document.getElementById('modal-issue-info') as HTMLElement;
	let currentIssueNumber = 0;

	function openAttachmentModal(issueNumber: number, issueTitle: string) {
		currentIssueNumber = issueNumber;
		modalIssueInfo.textContent = `#${issueNumber} - ${issueTitle}`;
		modalFile.value = '';
		modalStatus.style.display = 'none';
		modalSubmit.disabled = false;
		modal.style.display = 'flex';
	}

	function closeModal() {
		modal.style.display = 'none';
		currentIssueNumber = 0;
	}

	modalClose.addEventListener('click', closeModal);
	modal.addEventListener('click', (e) => {
		if (e.target === modal) closeModal();
	});

	modalSubmit.addEventListener('click', async () => {
		const selectedFiles = modalFile.files;
		const lang = getLang();

		if (!selectedFiles || selectedFiles.length === 0) {
			alert(lang === 'es' ? 'Selecciona al menos un archivo.' : 'Please select at least one file.');
			return;
		}

		const maxSize = 50 * 1024 * 1024; // 50MB per file
		for (const file of Array.from(selectedFiles)) {
			if (file.size > maxSize) {
				const msg = lang === 'es'
					? `"${file.name}" es muy grande (${(file.size / 1024 / 1024).toFixed(1)}MB). Máximo 50MB por archivo.`
					: `"${file.name}" is too large (${(file.size / 1024 / 1024).toFixed(1)}MB). Maximum 50MB per file.`;
				alert(msg);
				return;
			}
		}

		modalSubmit.disabled = true;
		modalStatus.style.display = 'block';
		modalStatus.className = 'modal-status';

		try {
			const uploadedFiles: { name: string; url: string }[] = [];
			const totalFiles = selectedFiles.length;

			for (let i = 0; i < totalFiles; i++) {
				const file = selectedFiles[i];
				modalStatus.textContent = lang === 'es'
					? `Subiendo ${i + 1} de ${totalFiles}...`
					: `Uploading ${i + 1} of ${totalFiles}...`;

				const blob = await upload(`bug-attachments/issue-${currentIssueNumber}/${file.name}`, file, {
					access: 'public',
					handleUploadUrl: '/api/upload-file',
				});
				uploadedFiles.push({ name: file.name, url: blob.url });
			}

			modalStatus.textContent = lang === 'es' ? 'Actualizando reporte...' : 'Updating report...';

			const res = await fetch('/api/update-bug', {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					issueNumber: currentIssueNumber,
					files: uploadedFiles,
				}),
			});

			if (!res.ok) throw new Error('Failed');

			const successMsg = lang === 'es'
				? `${uploadedFiles.length} archivo(s) subido(s) correctamente.`
				: `${uploadedFiles.length} file(s) uploaded successfully.`;
			modalStatus.textContent = successMsg;
			modalStatus.className = 'modal-status modal-success';

			setTimeout(async () => {
				closeModal();
				const bugList = document.getElementById('bug-list') as HTMLElement;
				bugList.innerHTML = '<p class="empty-state loading">Loading...</p>';
				const reports = await fetchIssues();
				allReports = reports;
				renderReports();
			}, 1500);
		} catch {
			modalSubmit.disabled = false;
			modalStatus.textContent = lang === 'es' ? 'Error al subir los archivos.' : 'Failed to upload files.';
			modalStatus.className = 'modal-status modal-error';
		}
	});
</script>

<style>
	.dashboard-header {
		margin-bottom: 2em;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		color: var(--paragraph);
		text-decoration: none;
		font-size: 0.9em;
		margin-bottom: 1em;
		transition: color 0.15s ease;
	}

	.back-link:hover {
		color: var(--highlight);
	}

	.dashboard-title h1 {
		margin-bottom: 0.25em;
	}

	.dashboard-title p {
		color: var(--paragraph);
		margin: 0;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1em;
		margin-bottom: 2em;
	}

	.stat-card {
		background: var(--card-bg);
		border-radius: 12px;
		padding: 1.5em;
		text-align: center;
		border: 2px solid transparent;
	}

	.stat-card.stat-open {
		border-color: var(--highlight);
	}

	.stat-card.stat-progress {
		border-color: var(--button);
	}

	.stat-card.stat-fixed {
		border-color: #4caf50;
	}

	.stat-number {
		display: block;
		font-size: 2.5em;
		font-weight: 700;
		color: var(--headline);
		line-height: 1;
	}

	.stat-label {
		display: block;
		font-size: 0.8em;
		color: var(--paragraph);
		margin-top: 0.5em;
		font-weight: 700;
	}

	.filters {
		display: flex;
		gap: 0.5em;
		margin-bottom: 1.5em;
		flex-wrap: wrap;
	}

	.filter-btn {
		padding: 0.5em 1.25em;
		border: 2px solid var(--stroke);
		border-radius: 20px;
		background: transparent;
		color: var(--paragraph);
		font-family: inherit;
		font-size: 0.85em;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.15s ease;
	}

	.filter-btn:hover {
		border-color: var(--highlight);
		color: var(--highlight);
	}

	.filter-btn.active {
		background: var(--stroke);
		color: var(--button-text);
		border-color: var(--stroke);
	}

	.bug-list {
		display: flex;
		flex-direction: column;
		gap: 1em;
	}

	.empty-state {
		text-align: center;
		color: var(--paragraph);
		padding: 3em;
		background: var(--card-bg);
		border-radius: 12px;
	}

	:global(.bug-card) {
		display: block;
		background: var(--card-bg);
		border-radius: 12px;
		padding: 1.5em;
		border-left: 4px solid var(--stroke);
		transition: transform 0.15s ease;
		text-decoration: none;
		color: inherit;
	}

	:global(.bug-card:hover) {
		transform: translateX(4px);
	}

	:global(.bug-card[data-status="open"]) {
		border-left-color: var(--highlight);
	}

	:global(.bug-card[data-status="in-progress"]) {
		border-left-color: var(--button);
	}

	:global(.bug-card[data-status="fixed"]) {
		border-left-color: #4caf50;
	}

	:global(.bug-card-header) {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1em;
		margin-bottom: 0.75em;
	}

	:global(.bug-info h3) {
		margin: 0 0 0.25em;
		color: var(--headline);
		font-size: 1.1em;
	}

	:global(.bug-project) {
		font-size: 0.75em;
		background: var(--bg);
		padding: 0.2em 0.6em;
		border-radius: 12px;
		color: var(--paragraph);
		font-weight: 700;
	}

	:global(.status-badge) {
		padding: 0.25em 0.75em;
		border-radius: 20px;
		font-size: 0.75em;
		font-weight: 700;
		white-space: nowrap;
	}

	:global(.status-open) {
		background: var(--highlight);
		color: var(--button-text);
	}

	:global(.status-in-progress) {
		background: var(--button);
		color: var(--button-text);
	}

	:global(.status-fixed) {
		background: #4caf50;
		color: #fff;
	}

	:global(.bug-description) {
		color: var(--paragraph);
		font-size: 0.9em;
		margin: 0 0 1em;
		line-height: 1.5;
	}

	:global(.bug-meta) {
		display: flex;
		justify-content: space-between;
		font-size: 0.8em;
		color: var(--paragraph);
		opacity: 0.7;
	}

	:global(.bug-card-link) {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	:global(.btn-attach) {
		background: transparent;
		border: 1px solid var(--stroke);
		color: var(--paragraph);
		padding: 0.2em 0.6em;
		border-radius: 6px;
		font-size: 0.75em;
		font-family: inherit;
		cursor: pointer;
		transition: all 0.15s ease;
	}

	:global(.btn-attach:hover) {
		border-color: var(--highlight);
		color: var(--highlight);
	}

	:global(.bug-meta-right) {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}

	:global(.attachment-badge) {
		font-size: 0.7em;
		background: var(--highlight);
		color: var(--button-text);
		padding: 0.15em 0.5em;
		border-radius: 10px;
		font-weight: 700;
	}

	.modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.6);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1000;
	}

	.modal-content {
		background: var(--bg);
		border-radius: 12px;
		padding: 2em;
		max-width: 500px;
		width: 90%;
		border: 1px solid var(--stroke);
	}

	.modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1em;
	}

	.modal-header h3 {
		margin: 0;
		color: var(--headline);
	}

	.modal-close {
		background: none;
		border: none;
		font-size: 1.5em;
		color: var(--paragraph);
		cursor: pointer;
		padding: 0;
		line-height: 1;
	}

	.modal-issue-info {
		color: var(--paragraph);
		font-size: 0.9em;
		margin-bottom: 1.5em;
	}

	.modal-content .form-group {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		margin-bottom: 1.5em;
	}

	.modal-content .form-group label {
		font-weight: 700;
		color: var(--headline);
		font-size: 0.9em;
	}

	.modal-content .form-group input[type="file"] {
		padding: 0.5em;
		cursor: pointer;
		border: 2px solid var(--stroke);
		border-radius: 8px;
		background: var(--card-bg);
		color: var(--headline);
	}

	.file-hint {
		font-size: 0.75em;
		color: var(--paragraph);
		opacity: 0.7;
	}

	.modal-content .btn-submit {
		background: var(--highlight);
		color: var(--button-text);
		padding: 0.75em 1.5em;
		border-radius: 8px;
		font-size: 1rem;
		font-weight: 700;
		cursor: pointer;
		border: none;
		font-family: inherit;
		width: 100%;
	}

	.modal-content .btn-submit:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.modal-status {
		text-align: center;
		margin-top: 1em;
		font-size: 0.9em;
		color: var(--paragraph);
	}

	.modal-success {
		color: #4caf50;
	}

	.modal-error {
		color: #f44336;
	}

	@media (max-width: 720px) {
		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		:global(.bug-card-header) {
			flex-direction: column;
		}

		:global(.bug-meta-right) {
			flex-wrap: wrap;
		}
	}
</style>
