---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects - ${SITE_TITLE}`} description="My projects and tools" />
	</head>
	<body>
		<Header />
		<main>
			<section class="projects-section">
				<h1 data-i18n="projectsTitle">Projects</h1>

				<div class="project-card">
					<div class="project-header">
						<h2>PDF Selector</h2>
						<span class="badge" id="version-badge">Latest: ...</span>
					</div>
					<p data-i18n="pdfSelectorDesc">
						A desktop tool to rename and organize PDF files quickly and efficiently.
						Select, rename, and manage your PDF documents with ease.
					</p>
					<div class="project-links">
						<a
							id="download-exe-link"
							href="#"
							class="btn btn-download"
							download
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
								<polyline points="7 10 12 15 17 10"/>
								<line x1="12" y1="15" x2="12" y2="3"/>
							</svg>
							<span data-i18n="downloadExe">Download .exe</span>
						</a>
						<a
							href="https://pdf-selector.vercel.app/"
							class="btn btn-web"
							target="_blank"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"/>
								<line x1="2" y1="12" x2="22" y2="12"/>
								<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
							</svg>
							<span data-i18n="webVersion">Web Version</span>
						</a>
					</div>
				</div>
			</section>

			<section class="bug-report-section">
				<div class="section-header">
					<h2 data-i18n="bugReportTitle">Report a Bug</h2>
					<a href="/projects/dashboard" class="btn btn-dashboard">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="3" width="7" height="7"/>
							<rect x="14" y="3" width="7" height="7"/>
							<rect x="3" y="14" width="7" height="7"/>
							<rect x="14" y="14" width="7" height="7"/>
						</svg>
						<span data-i18n="viewDashboard">View Bug Tracker</span>
					</a>
				</div>
				<p data-i18n="bugReportDesc">Found an issue with one of the projects? Fill out the form below to let me know.</p>

				<form class="bug-form" id="bug-form">
					<div class="form-group">
						<label for="project" data-i18n="projectLabel">Project</label>
						<select id="project" name="project" required>
							<option value="" data-i18n="selectProject">Select a project...</option>
							<option value="pdf-selector">PDF Selector</option>
						</select>
					</div>

					<div class="form-group">
						<label for="name" data-i18n="yourName">Your Name</label>
						<input type="text" id="name" name="name" placeholder="John Doe" required />
					</div>

					<div class="form-group">
						<label for="email" data-i18n="email">Email</label>
						<input type="email" id="email" name="email" placeholder="john@example.com" required />
					</div>

					<div class="form-group">
						<label for="bug-title" data-i18n="bugTitle">Bug Title</label>
						<input type="text" id="bug-title" name="bug-title" data-i18n-placeholder="bugTitlePlaceholder" placeholder="Brief description of the issue" required />
					</div>

					<div class="form-group">
						<label for="description" data-i18n="description">Description</label>
						<textarea id="description" name="description" rows="5" data-i18n-placeholder="descriptionPlaceholder" placeholder="Please describe the bug in detail. Include steps to reproduce, expected behavior, and what actually happened." required></textarea>
					</div>

					<div class="form-group">
						<label for="file-upload" data-i18n="uploadFile">Upload File (optional)</label>
						<input type="file" id="file-upload" name="file-upload" accept="image/*,.pdf,.log,.txt" multiple />
						<span class="file-hint" data-i18n="fileHint">Supports images, PDF, .log, and .txt (max 50MB per file)</span>
					</div>

					<button type="submit" class="btn btn-submit" data-i18n="submitBugReport">Submit Bug Report</button>
				</form>

				<div class="form-success" id="form-success" style="display: none;">
					<p data-i18n="thankYouReport">Thank you for your report! I'll look into it as soon as possible.</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	import { upload } from '@vercel/blob/client';
	import { translations } from '../../i18n';
	type Lang = keyof typeof translations;
	type TranslationKey = keyof (typeof translations)['en'];

	// Form submission
	const form = document.getElementById('bug-form') as HTMLFormElement;
	const success = document.getElementById('form-success') as HTMLElement;
	const submitBtn = form.querySelector('.btn-submit') as HTMLButtonElement;
	const nameInput = document.getElementById('name') as HTMLInputElement;
	const emailInput = document.getElementById('email') as HTMLInputElement;
	const fileInput = document.getElementById('file-upload') as HTMLInputElement;

	// Restore saved user info
	const savedName = localStorage.getItem('bugReporter_name');
	const savedEmail = localStorage.getItem('bugReporter_email');
	if (savedName) nameInput.value = savedName;
	if (savedEmail) emailInput.value = savedEmail;

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		submitBtn.disabled = true;
		const lang = localStorage.getItem('lang') || 'en';
		submitBtn.textContent = '...';

		const formData = new FormData(form);
		const nameVal = formData.get('name') as string;
		const emailVal = formData.get('email') as string;

		// Save user info for next time
		localStorage.setItem('bugReporter_name', nameVal);
		localStorage.setItem('bugReporter_email', emailVal);

		const payload: Record<string, string | null> = {
			project: formData.get('project') as string,
			name: nameVal,
			email: emailVal,
			title: formData.get('bug-title') as string,
			description: formData.get('description') as string,
		};

		// Upload files to Vercel Blob if provided
		const selectedFiles = fileInput.files;
		const uploadedFiles: { name: string; url: string }[] = [];
		const failedFiles: string[] = [];
		if (selectedFiles && selectedFiles.length > 0) {
			const maxSize = 50 * 1024 * 1024; // 50MB per file
			for (const file of Array.from(selectedFiles)) {
				if (file.size > maxSize) {
					submitBtn.disabled = false;
					submitBtn.textContent = lang === 'es' ? 'Enviar Reporte de Error' : 'Submit Bug Report';
					const msg = lang === 'es'
						? `"${file.name}" es muy grande (${(file.size / 1024 / 1024).toFixed(1)}MB). Máximo 50MB por archivo.`
						: `"${file.name}" is too large (${(file.size / 1024 / 1024).toFixed(1)}MB). Maximum 50MB per file.`;
					alert(msg);
					return;
				}
			}
			const timestamp = Date.now();
			for (const file of Array.from(selectedFiles)) {
				try {
					const blob = await upload(`bug-attachments/${timestamp}-${file.name}`, file, {
						access: 'public',
						handleUploadUrl: '/api/upload-file',
					});
					uploadedFiles.push({ name: file.name, url: blob.url });
				} catch {
					failedFiles.push(file.name);
				}
			}
			if (failedFiles.length > 0 && uploadedFiles.length === 0) {
				submitBtn.disabled = false;
				submitBtn.textContent = lang === 'es' ? 'Enviar Reporte de Error' : 'Submit Bug Report';
				alert(lang === 'es' ? 'Error al subir los archivos.' : 'Failed to upload files.');
				return;
			}
		}
		if (uploadedFiles.length > 0) {
			(payload as Record<string, unknown>).files = uploadedFiles;
		}

		try {
			const res = await fetch('/api/report-bug', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});

			if (!res.ok) throw new Error('Failed');

			form.style.display = 'none';
			success.style.display = 'block';
		} catch {
			submitBtn.disabled = false;
			const lang = localStorage.getItem('lang') || 'en';
			submitBtn.textContent =
				lang === 'es'
					? 'Enviar Reporte de Error'
					: 'Submit Bug Report';
			alert(
				lang === 'es'
					? 'Error al enviar el reporte. Intenta de nuevo.'
					: 'Failed to submit report. Please try again.'
			);
		}
	});

	// i18n
	function applyLang(lang: Lang) {
		const t = translations[lang];
		document.documentElement.lang = lang;
		document.querySelectorAll('[data-i18n]').forEach((el) => {
			const key = (el as HTMLElement).dataset.i18n as TranslationKey;
			if (t[key]) el.textContent = t[key];
		});
		document.querySelectorAll('[data-i18n-html]').forEach((el) => {
			const key = (el as HTMLElement).dataset.i18nHtml as TranslationKey;
			if (t[key]) el.innerHTML = t[key];
		});
		document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
			const key = (el as HTMLElement).dataset.i18nPlaceholder as TranslationKey;
			if (t[key]) (el as HTMLInputElement).placeholder = t[key];
		});
	}

	const lang = (localStorage.getItem('lang') || 'en') as Lang;
	applyLang(lang);
	document.addEventListener('langchange', (e) => {
		applyLang((e as CustomEvent).detail.lang as Lang);
	});

	// Fetch latest release from GitHub
	const REPO = 'Baku452/pdf-selector';
	const versionBadge = document.getElementById('version-badge') as HTMLElement;
	const downloadLink = document.getElementById('download-exe-link') as HTMLAnchorElement;

	fetch(`https://api.github.com/repos/${REPO}/releases?per_page=10`, {
		headers: { Accept: 'application/vnd.github+json' },
		cache: 'no-store',
	})
		.then((res) => res.json())
		.then((releases: { tag_name: string; prerelease: boolean; html_url: string; assets: { name: string; browser_download_url: string }[] }[]) => {
			// Find the first stable release that has a .exe asset
			const release = releases.find((r) =>
				!r.prerelease &&
				r.assets?.some((a) => a.name.endsWith('.exe'))
			);
			if (!release) {
				downloadLink.href = `https://github.com/${REPO}/releases`;
				return;
			}
			versionBadge.textContent = `Latest: ${release.tag_name}`;
			const exeAsset = release.assets.find((a) => a.name.endsWith('.exe'))!;
			downloadLink.href = exeAsset.browser_download_url;
		})
		.catch(() => {
			versionBadge.textContent = 'Latest';
			downloadLink.href = `https://github.com/${REPO}/releases/latest`;
		});
</script>

<style>
	.projects-section {
		margin-bottom: 3em;
	}

	.project-card {
		background: var(--card-bg);
		border: 1px solid var(--stroke);
		border-radius: 12px;
		padding: 2em;
		margin-top: 1.5em;
	}

	.project-header {
		display: flex;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
	}

	.project-header h2 {
		margin: 0;
		color: var(--card-text);
	}

	.badge {
		background: var(--highlight);
		color: var(--button-text);
		padding: 0.25em 0.75em;
		border-radius: 20px;
		font-size: 0.75em;
		font-weight: 700;
	}

	.project-card p {
		color: var(--paragraph);
		margin: 1em 0 1.5em;
	}

	.project-links {
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.75em 1.5em;
		border-radius: 8px;
		font-size: 1rem;
		font-weight: 700;
		text-decoration: none;
		cursor: pointer;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
		border: none;
		font-family: inherit;
	}

	.btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(var(--black), 15%);
	}

	.btn-download {
		background: var(--matcha);
		color: var(--button-text);
	}

	.btn-download:hover {
		background: var(--matcha-dark);
		color: var(--button-text);
	}

	.btn-web {
		background: var(--highlight);
		color: var(--button-text);
	}

	.btn-web:hover {
		color: var(--button-text);
	}

	.section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1em;
		margin-bottom: 0.25em;
	}

	.section-header h2 {
		margin: 0;
	}

	.btn-dashboard {
		background: var(--stroke);
		color: var(--button-text);
		padding: 0.5em 1em;
		font-size: 0.85rem;
	}

	.btn-dashboard:hover {
		color: var(--button-text);
	}

	.bug-report-section {
		background: var(--card-bg);
		border-radius: 12px;
		padding: 2em;
		margin-bottom: 2em;
	}

	.bug-report-section h2 {
		color: var(--card-text);
	}

	.bug-report-section > p {
		color: var(--paragraph);
		margin-bottom: 1.5em;
	}

	.bug-form {
		display: flex;
		flex-direction: column;
		gap: 1.25em;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}

	.form-group label {
		font-weight: 700;
		color: var(--headline);
		font-size: 0.9em;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		padding: 0.75em 1em;
		border: 2px solid var(--stroke);
		border-radius: 8px;
		background: var(--bg);
		color: var(--headline);
		font-size: 1rem;
		font-family: inherit;
		transition: border-color 0.15s ease;
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--highlight);
	}

	.form-group input[type="file"] {
		padding: 0.5em;
		cursor: pointer;
	}

	.file-hint {
		font-size: 0.75em;
		color: var(--paragraph);
		opacity: 0.7;
	}

	.btn-submit {
		background: var(--highlight);
		color: var(--button-text);
		padding: 0.85em 2em;
		align-self: flex-start;
	}

	.form-success {
		text-align: center;
		padding: 2em;
	}

	.form-success p {
		color: var(--card-text);
		font-size: 1.15em;
		font-weight: 700;
	}

	@media (max-width: 720px) {
		.project-card,
		.bug-report-section {
			padding: 1.25em;
		}

		.project-links {
			flex-direction: column;
		}

		.btn {
			justify-content: center;
		}
	}
</style>
