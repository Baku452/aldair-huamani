---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Aldair Huamani</h1>
      <p data-i18n-html="homeIntro1">
        Currently, I'm a software engineer at <a
          href="https://www.globant.com/"
          target="_blank"
          rel="noopener noreferrer">Globant</a
        >
      </p>
      <p data-i18n-html="homeIntro2">
        Working on side projects when free time is available
      </p>
      <img src="/images/monkey-pissed.gif" alt="Description of GIF" />
    </main>
    <Footer />
    <script>
      import { translations } from '../i18n';
      type Lang = keyof typeof translations;
      type TranslationKey = keyof (typeof translations)['en'];

      function applyLang(lang: Lang) {
        const t = translations[lang];
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = (el as HTMLElement).dataset.i18n as TranslationKey;
          if (t[key]) el.textContent = t[key];
        });
        document.querySelectorAll('[data-i18n-html]').forEach((el) => {
          const key = (el as HTMLElement).dataset.i18nHtml as TranslationKey;
          if (t[key]) el.innerHTML = t[key];
        });
      }

      const lang = (localStorage.getItem('lang') || 'en') as Lang;
      applyLang(lang);
      document.addEventListener('langchange', (e) => {
        applyLang((e as CustomEvent).detail.lang as Lang);
      });
    </script>
  </body>
</html>
